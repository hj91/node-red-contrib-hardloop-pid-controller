  },
  "bugs": {
    "url": "https://github.com/hj91/node-red-contrib-hardloop-pid-controller/issues"
  },
  "homepage": "https://github.com/hj91/node-red-contrib-hardloop-pid-controller#readme",
  "engines": {
    "node": ">=16.0.0"
  }
}
